@using System.Security.Claims;

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>Bienvenido Mr/Ms @Context.User.Identity.Name</h1>

            <div class="card mt-4">
                <div class="card-header bg-primary text-white">
                    <h4>Información del Empleado</h4>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>Oficio:</strong> @Context.User.FindFirst(ClaimTypes.Role).Value
                        </li>
                        <li class="list-group-item">
                            <strong>Salario:</strong> @Context.User.FindFirst("Salario").Value €
                        </li>
                        <li class="list-group-item">
                            <strong>Departamento:</strong> @Context.User.FindFirst("Departamento").Value
                        </li>
                        <li class="list-group-item">
                            <strong>ID Empleado:</strong> @Context.User.FindFirst(ClaimTypes.NameIdentifier).Value
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header bg-info text-white">
                    <h5>📋 Todos los Claims del Usuario</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        @foreach (Claim claim in Context.User.Claims)
                        {
                            <li class="list-group-item">
                                <strong>@claim.Type:</strong> @claim.Value
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="text-center">
                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="Empleado" class="img-fluid" style="max-width: 200px;" />
            </div>

            <div class="alert alert-warning mt-4">
                <h5>🔐 Permisos de Eliminación</h5>
                <p class="mb-0">
                    <strong>Estado:</strong> 
                    Solo podrás eliminar empleados si tienes subordinados a tu cargo.
                </p>
                <hr>
                <p class="mb-0 text-muted small">
                    La funcionalidad de eliminar requiere que tengas empleados con tu ID en el campo DIR.
                </p>
            </div>
        </div>
    </div>
</div>


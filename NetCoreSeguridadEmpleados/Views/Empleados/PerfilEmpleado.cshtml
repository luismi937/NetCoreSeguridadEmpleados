@using System.Security.Claims;



<h1>Bienvenido Mr/Ms @Context.User.Identity.Name</h1>

<ul>
    <li>
        Oficio: @Context.User.FindFirst(ClaimTypes.Role).Value
    </li>
    <li>
        Salario: @Context.User.FindFirst("Salario").Value
    </li>
    <li>
        Departamento: @Context.User.FindFirst("Departamento").Value
    </li>
</ul>

<h4>Todos los claims del usuario</h4>
<ul>
    @foreach (Claim claim in Context.User.Claims)
    {
        <li>
            @claim.Type : @claim.Value
        </li>
    }
</ul>

<img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="Empleado" width="150" height="150" />

